{
  "project": {
    "name": "core-application-agents-AI",
    "domain": "Fintech Platform — 3 Microservicios: Auth, Transacciones y Consultas",
    "repos": {
      "agents": "core-application-agents-AI — configuración de agentes Claude",
      "microservice1": "auth-service — OAuth 2.0, MySQL (⏳ por crear)",
      "microservice2": "core-transactions-service (PruebaNetCoreProject) — Write CQRS, MySQL + Kafka (✅ scaffolding)",
      "microservice3": "account-queries-service — Read CQRS, MongoDB + Redis + Kafka (⏳ por crear)",
      "gateway": "api-gateway — YARP .NET Core 9 (⏳ por crear)",
      "frontend": "fintech-frontend — Next.js 15 SSR (rama: feature/first) (⏳ por crear)"
    },
    "stack": {
      "backend": ".NET Core 9 (C#) — 3 microservicios REST API + YARP Gateway",
      "frontend": "Next.js 15 (React 19 + TypeScript) — SSR (Server-Side Rendering)",
      "architecture": "Hexagonal (Puertos y Adaptadores) + DDD por microservicio",
      "pattern": "CQRS con MediatR — Commands (MySQL) / Queries (MongoDB + Redis) separados en servicios distintos",
      "messaging": "Kafka 3.7 (bitnami KRaft) + MassTransit 8.x — EDA con Outbox Pattern",
      "cache": "Redis 7 (StackExchange.Redis) — Cache-Aside e idempotencia",
      "security": "OAuth 2.0 + JWT — validación exclusiva en Adaptadores Inbound",
      "infrastructure": "Docker Compose — mysql-fintech, mongodb-fintech, redis-fintech, kafka-fintech, kafka-ui-fintech",
      "codeQuality": "SonarLint (IDE) + SonarAnalyzer.CSharp (backend) + eslint-plugin-sonarjs (frontend)",
      "persistence": {
        "writeStore": "MySQL 8 Docker (Pomelo EF Core 9) — auth-service + core-transactions-service",
        "readStore": "MongoDB 7 Docker (MongoDB.Driver 3) — account-queries-service",
        "cacheStore": "Redis 7 Docker (StackExchange.Redis) — account-queries-service",
        "eventStore": "outbox_messages (MySQL) — garantia at-least-once a Kafka"
      },
      "framework": "BIAN v12 — dominios de servicio bancarios"
    }
  },
  "mcpServers": {
    "_note": "MCP servers para validación directa de bases de datos por los agentes. Configurar también en Windsurf Settings > MCP para activación en el IDE.",
    "mysql-fintech": {
      "command": "npx",
      "args": ["-y", "@benborla29/mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "127.0.0.1",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASS": "fintechroot2024",
        "MYSQL_DB": "fintech_db",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      },
      "description": "MySQL Docker (mysql-fintech) — validación de esquema transaccional (solo lectura en agentes)"
    },
    "mongodb-fintech": {
      "command": "npx",
      "args": [
        "-y",
        "@mongodb-js/mongodb-mcp-server",
        "--connectionString",
        "mongodb://localhost:27017/"
      ],
      "description": "MongoDB local — validación de colecciones de read models y audit log"
    },
    "redis-fintech": {
      "command": "npx",
      "args": ["-y", "redis-mcp"],
      "env": {
        "REDIS_URL": "redis://:fintech2024@localhost:6379"
      },
      "description": "Redis Docker (redis-fintech) — validación de caché, TTL y claves de idempotencia"
    }
  },
  "permissions": {
    "allow": [
      "read",
      "search",
      "grep",
      "glob",
      "cat",
      "git status",
      "git log",
      "git diff",
      "dotnet build",
      "dotnet test",
      "dotnet run",
      "dotnet ef",
      "npm run build",
      "npm run test",
      "npm run lint",
      "npx",
      "docker ps",
      "docker compose ps",
      "docker compose up",
      "docker compose down",
      "docker exec",
      "dir",
      "find"
    ],
    "deny": [
      "rm -rf",
      "git push --force",
      "git push -f",
      "DROP ",
      "TRUNCATE ",
      "DELETE FROM",
      "UPDATE ",
      "INSERT INTO",
      "ALTER TABLE DROP",
      "db.dropDatabase",
      "db.collection.drop",
      "rm -r",
      "del /f /s /q",
      "rmdir /s /q",
      "format",
      "diskpart"
    ]
  },
  "tooling": {
    "backendCompiler": "dotnet build",
    "backendTestRunner": "dotnet test",
    "backendMigrationTool": "dotnet ef migrations add",
    "backendLinter": "SonarLint IDE + SonarAnalyzer.CSharp NuGet",
    "frontendPackageManager": "npm",
    "frontendBundler": "Next.js 15 (Turbopack)",
    "frontendTestRunner": "Jest + React Testing Library + Playwright",
    "frontendLinter": "ESLint + eslint-plugin-sonarjs",
    "infrastructure": "Docker Compose (docker-compose.infra.yml)",
    "messageBroker": "Apache Kafka 3.7 (bitnami KRaft) + MassTransit 8.x",
    "kafkaUI": "http://localhost:8090 (kafka-ui-fintech)",
    "preferredShell": "powershell"
  },
  "agents": {
    "backendOrchestrator": "fullstack-engineer",
    "security": "senior-security-architect",
    "backend": "senior-backend-engineer",
    "cqrs": "senior-cqrs-specialist",
    "dba": "senior-dba",
    "frontend": "senior-frontend-engineer"
  },
  "directories": {
    "agents": ".claude/agents",
    "commands": ".claude/commands",
    "rules": ".claude/rules",
    "contexts": ".claude/contexts",
    "lessonsLearned": "docs/lessons-learned"
  },
  "securityRules": {
    "domainMustNotImport": [
      "Microsoft.AspNetCore.Authorization",
      "IdentityModel",
      "System.Security.Claims",
      "Microsoft.AspNetCore.Http",
      "Microsoft.EntityFrameworkCore",
      "StackExchange.Redis",
      "MongoDB.Driver",
      "MassTransit"
    ],
    "oauthValidationLayer": "Infrastructure/Adaptadores Inbound",
    "sensitiveDataInLogs": false,
    "mcpReadOnly": true,
    "sonarLintRequired": true,
    "sonarCriticalBlocksRelease": true,
    "noDirectServiceToServiceHttp": true,
    "interServiceComm": "Kafka via MassTransit (EDA) — nunca HTTP directo entre microservicios",
    "dockerRequired": true,
    "kafkaOutboxRequired": "Todo Command que modifica estado DEBE publicar via Outbox Pattern"
  },
  "infrastructure": {
    "dockerComposeFile": "docker/docker-compose.infra.yml",
    "containers": {
      "mysql": { "name": "mysql-fintech", "port": 3306, "image": "mysql:8.0" },
      "mongodb": { "name": "mongodb-fintech", "port": 27017, "image": "mongo:7.0" },
      "redis": { "name": "redis-fintech", "port": 6379, "image": "redis:7-alpine" },
      "kafka": { "name": "kafka-fintech", "port": 9092, "image": "bitnami/kafka:3.7" },
      "kafkaUI": { "name": "kafka-ui-fintech", "port": 8090, "image": "provectuslabs/kafka-ui" }
    },
    "kafkaTopics": [
      "fintech.transactions.executed",
      "fintech.transactions.failed",
      "fintech.accounts.balance-updated",
      "fintech.accounts.status-changed",
      "fintech.auth.user-registered",
      "fintech.auth.session-revoked"
    ]
  },
  "logging": {
    "level": "info",
    "storeDecisions": true
  }
}
